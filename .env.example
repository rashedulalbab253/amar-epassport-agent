# =============================================================
# Bangladesh E-Passport Virtual Consular Officer
# Environment Configuration
# =============================================================

# --- LLM Provider Configuration ---
# Choose your LLM provider: "openai" or "google"
LLM_PROVIDER=google

# OpenAI Configuration (if using OpenAI)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_NAME=gpt-4o-mini

# Google Gemini Configuration (if using Google)
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL_NAME=gemini/gemini-2.0-flash

# --- Application Settings ---
# Verbosity for CrewAI agents (true/false)
CREW_VERBOSE=true

# Temperature for LLM responses (0.0 - 1.0)
LLM_TEMPERATURE=0.1

# --- Streamlit Settings ---
STREAMLIT_PORT=8501
